## Converted from HaikuArchives/Slayer Makefile (real-world Haiku process manager)

NAME = Slayer ;
TYPE = APP ;
APP_MIME_SIG = application/x-vnd.AJ-Slayer2 ;

SRCS = Hashtable.cpp
    MainWindow.cpp
    MiniSlayer.cpp
    miscSlayer.cpp
    Options.cpp
    PositiveIntegerColumn.cpp
    PriorityMenu.cpp
    SettingsWindow.cpp
    SizeColumn.cpp
    SlayerApp.cpp
    TeamItem.cpp
    TeamListView.cpp
    ThreadItem.cpp ;

RDEFS = Slayer.rdef ;
RSRCS = ;

LIBS = be columnlistview localestub shared translation ;

LIBPATHS = ;
SYSTEM_INCLUDE_PATHS = ;
LOCAL_INCLUDE_PATHS = ;

OPTIMIZE = FULL ;
LOCALES = ca da de en_AU en_GB en es es_419 fr fur hu it ko nb pl pt ro ru sv tr uk zh-Hans ;
DEFINES = ;
WARNINGS = ;
SYMBOLS = ;
DEBUGGER = ;
COMPILER_FLAGS = ;
LINKER_FLAGS = ;
DRIVER_PATH = ;

include $(BUILDHOME)/etc/Jamfile-engine ;
